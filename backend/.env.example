# Django Settings
SECRET_KEY=django-insecure-your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (PostgreSQL defaults)
# Set USE_POSTGRES=False to fallback to SQLite for local development
USE_POSTGRES=False
DB_NAME=relationship_resolver
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis Channel Layer Configuration (Optional, defaults to InMemory if empty/unset)
REDIS_URL=

# Google Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Vector DB Configuration
CHROMA_DB_PATH=./chroma_db
